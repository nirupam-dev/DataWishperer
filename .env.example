# ─────────────────────────────────────────────────────────────────────────────
# DataWhisperer — Environment Configuration
#
# Copy this file to .env and customise values for your deployment.
# All variables have sensible defaults; only override what you need.
#
# Docker Compose reads this file automatically.
# For native installs, the app reads .env via pydantic-settings.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_NAME=DataWhisperer
APP_VERSION=1.0.0
APP_DEBUG=false
# Port exposed on the host machine
APP_PORT=8501
# If true, disables cloud LLMs and uses local Ollama only
APP_LOCAL_ONLY_MODE=false

# ── Groq API (Primary LLM Provider) ──────────────────────────
# Required for Groq usage; leave empty to auto-fallback to Ollama.
# Accepts GROQ_API_KEY or XAI_API_KEY (legacy alias).
# Add GROQ_API_KEY_2 as a backup; the app auto-rotates on rate-limit/expiry.
GROQ_API_KEY=
GROQ_API_KEY_2=
GROK_BASE_URL=https://api.groq.com/openai/v1
GROK_MODEL=llama-3.3-70b-versatile
GROK_TIMEOUT_SECONDS=45
GROK_MAX_RETRIES=2

# ── Ollama LLM Server (Fallback Provider) ───────────────────
# For Docker: leave as default (Docker networking resolves "ollama")
# For native: point to your local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# Host port for the Ollama API (Docker only)
OLLAMA_HOST_PORT=11434
# Sampling temperature (0.0 = deterministic, 2.0 = creative)
OLLAMA_TEMPERATURE=0.1
# Max tokens to generate per response
OLLAMA_NUM_PREDICT=2048
# Context window size (larger = more memory, better context)
OLLAMA_NUM_CTX=4096
# HTTP timeout for Ollama API calls (seconds)
OLLAMA_TIMEOUT=120

# ── Sandbox Execution ───────────────────────────────────────
# Maximum time (seconds) for a single code execution
SANDBOX_TIMEOUT=30
# Memory limit for sandbox subprocess (MB)
SANDBOX_MAX_MEMORY_MB=512
# Maximum stdout capture from sandbox (KB)
SANDBOX_MAX_OUTPUT_KB=256
# Retry count on LLM code generation failure
SANDBOX_MAX_RETRIES=2

# ── Storage ──────────────────────────────────────────────────
# Max upload file size (MB)
STORAGE_MAX_FILE_SIZE_MB=50
# Max CSV columns allowed
STORAGE_MAX_COLUMNS=500

# ── Chat ─────────────────────────────────────────────────────
# Total messages stored per session
CHAT_MAX_HISTORY_MESSAGES=20
# Recent messages included in LLM context window
CHAT_HISTORY_WINDOW_SIZE=6
# Max user query length (characters)
CHAT_MAX_QUERY_LENGTH=2000

# ── Logging ──────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
